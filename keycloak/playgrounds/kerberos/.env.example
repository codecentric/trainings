# Copy to .env — safe to use as-is for local playground.
# Change passwords before exposing this to any shared network.

# Kerberos
KRB5_REALM=EXAMPLE.COM
KEYCLOAK_HOST=localhost
KDC_PASSWORD=adminpassword
KDC_USER_PASSWORD=alice

# LDAP
# Note: if you change LDAP_ADMIN_PASSWORD, also update bindCredential
# in keycloak/realm-export.json (or reconfigure the LDAP federation in the UI).
# If you change the alice user password, update it in openldap/bootstrap.ldif too.
LDAP_ADMIN_PASSWORD=adminpassword
