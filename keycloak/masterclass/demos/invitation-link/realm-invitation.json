{
  "realm": "lab-realm",
  "enabled": true,
  "smtpServer": {
    "host": "mailhog",
    "port": "1025",
    "from": "keycloak@example.com",
    "fromDisplayName": "Keycloak",
    "auth": "false",
    "starttls": "false",
    "ssl": "false"
  },
  "clients": [
    {
      "clientId": "admin-api-client",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "admin-api-secret"
    }
  ],
  "users": [
    {
      "username": "invited-user",
      "email": "invited-user@example.com",
      "enabled": true,
      "emailVerified": false,
      "requiredActions": ["UPDATE_PASSWORD"]
    },
    {
      "username": "service-account-admin-api-client",
      "enabled": true,
      "serviceAccountClientId": "admin-api-client",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users"
        ]
      }
    }
  ]
}
