# Example Terraform variables file
# Copy this to terraform.tfvars and customize as needed
# cp terraform.tfvars.example terraform.tfvars

# Base URL of your Keycloak instance
# keycloak_base_url = "http://localhost:8080"

# Realm name in Keycloak where you'll configure Azure AD
# keycloak_realm = "labrealm"

# Whether to create a demo user in Azure AD for testing
# create_demo_user = true
